{
  "name": "@blog/api-admin",
  "private": true,
  "description": "Administrative Cloudflare Worker for the blog platform.",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "rust:fmt": "cargo +nightly fmt",
    "rust:fmt:check": "cargo +nightly fmt -- --check",
    "rust:lint": "cargo clippy --target wasm32-unknown-unknown -- -D warnings",
    "rust:check": "cargo check --target wasm32-unknown-unknown",
    "rust:test": "cargo test",
    "rust:build": "cargo install -q worker-build && worker-build --release",
    "worker:dev": "wrangler dev",
    "check": "pnpm run rust:fmt:check && pnpm run rust:lint && pnpm run rust:check && pnpm run rust:test"
  },
  "devDependencies": {
    "wrangler": "^4.81.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "workerd",
      "esbuild"
    ]
  }
}

