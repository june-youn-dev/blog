{
  "name": "@blog/site",
  "private": true,
  "description": "Static blog site generated by Eleventy from AsciiDoc content stored in D1.",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "ts:build": "node --experimental-strip-types scripts/build-browser-modules.mts",
    "ts:check": "pnpm exec tsc --project tsconfig.json",
    "fetch": "node --experimental-strip-types scripts/fetch-posts.mts",
    "fetch:check": "node --experimental-strip-types scripts/check-fetch-fixture.mts",
    "render:check": "node --experimental-strip-types scripts/check-render-fixture.mts",
    "build": "pnpm run ts:build && pnpm run fetch && pnpm exec eleventy",
    "dev": "pnpm run ts:build && pnpm exec eleventy --serve",
    "clean": "node --experimental-strip-types scripts/clean-generated.mts"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@asciidoctor/core": "^3.0.0",
    "@types/node": "^25.6.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "typescript": "^6.0.3"
  }
}
